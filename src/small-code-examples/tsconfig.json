{
 "compilerOptions": {
   "target": "ES2020",
   "module": "ESNext",
   "moduleResolution": "node",
   "esModuleInterop": true,
   "resolveJsonModule": true,
   "allowJs": false,
   "rootDir": ".",
   "outDir": "dist",
   "lib": ["ESNext", "DOM"],
   "declaration": false,
   "alwaysStrict": true,
   "strict": true,
   "noImplicitAny": true,
   "noFallthroughCasesInSwitch": true,
   "noImplicitReturns": true,
   "noUnusedLocals": true,
   "forceConsistentCasingInFileNames": true
 },
 "include": ["*.ts", "**/*.ts"],
 "exclude": ["node_modules", "dist"]
}
