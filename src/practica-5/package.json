{
  "name": "practica-5-de-pai",
  "version": "1.0.0",
  "description": "OOP en TS",
  "private": true,
  "main": "index.js",
  "scripts": {
    "push": "rm *~; git pull; git add . ; git commit -m 'Code improvement'; git push",
    "pull": "git pull",
    "test": "jest",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --no-error-on-unmatched-pattern",
    "lint:ci": "eslint \"src/**/*.{ts,tsx}\" --no-error-on-unmatched-pattern",
    "docs": "find src -type f -name '*.ts' | grep -q . && typedoc || echo 'No hay ficheros TypeScript en src para documentar'",
    "start": "tsc-watch --onSuccess \"node dist/index.js\""
  },
  "keywords": [
    "PAI"
  ],
  "author": "F. de Sande <fsande@ull.es>",
  "license": "MIT",
  "eslintConfig": {
    "extends": [
      "standard-with-typescript"
    ],
    "parserOptions": {
      "project": "./tsconfig.json"
    }
  },
  "typedocOptions": {
    "entryPoints": [
      "src"
    ],
    "entryPointStrategy": "expand",
    "out": "docs",
    "tsconfig": "tsconfig.json"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverage": true,
    "collectCoverageFrom": ["src/**/*.ts"]
  },
  "devDependencies": {
    "@exercism/babel-preset-typescript": "^0.1.0",
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.33",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "@typescript-eslint/parser": "^5.50.0",
    "babel-jest": "^29.7.0",
    "core-js": "^3.21.0",
    "eslint": "^8.33.0",
    "eslint-config-standard-with-typescript": "^34.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsc-watch": "^6.0.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "prompt-sync": "^4.2.0"
  },
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node"
  }
}